---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const repos = [
  {
    title: 'Portfolio y página personal',
    lang: 'Astro',
    year: '2026',
    desc: 'Código fuente de este sitio web personal. Construido con Astro, Tailwind CSS y desplegado con GitHub Pages. Este proyecto fue migrado de Jekyll.',
    href: 'https://github.com/CBaezaT/cbaezat.github.io',
  },
  {
    title: 'Predicción de Ventas - Series de Tiempo',
    lang: 'Python',
    year: '2025',
    desc: 'Trabajo competitivo de predicción de ventas para ajuste de stock. Entrega ganadora con el menor WMAE de la competencia. Utiliza modelos de series de tiempo ensamblados con Block Bootstrap.',
    href: 'https://github.com/CBaezaT/TimeSeries_Sales_Prediction_T2',
  },
  {
    title: 'Tarea 1 - Análisis de Mercado y WebScrapping',
    lang: 'Python',
    year: '2026',
    desc: 'Código fuente de la tarea 1 de análisis de mercado y webscrapping. Construido con Python. Utiliza un WebScrapper dinámico ensamblado con identificación de productos y análisis exploratorio de datos.',
    href: 'https://github.com/CBaezaT/Tarea-1-Analitica-de-Datos',
  },
  {
    title: 'Scripts de Análisis',
    lang: 'R',
    year: '2023',
    desc: 'Colección de scripts para análisis estadístico en antropología física. Incluye análisis demográficos y visualizaciones.',
    href: 'https://github.com/CBaezaT',
  },
];

const tecnologias = ['Python', 'R', 'JavaScript', 'SQL', 'Tailwind', 'Astro', 'Pandas', 'Scikit-learn', 'Docker', 'GitHub Actions', 'FastAPI', 'PostgreSQL'];
---

<Layout title="Repositorios - Cristian Baeza Torres">
  <div class="space-y-12">
    <div class="space-y-2 border-b border-bone-300 pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-clay">§ Código</p>
      <h1 class="font-serif text-4xl font-semibold text-ink">Repositorios</h1>
      <p class="text-lg text-ink-light">Proyectos y código mantenido en GitHub</p>
    </div>

    <!-- GitHub Profile Card -->
    <div class="bg-ink text-bone-100 p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 h-[3px] w-full bg-gradient-to-r from-clay via-clay-light to-moss"></div>
      <div class="flex items-center gap-6">
        <div class="w-20 h-20 border border-bone-300/40 flex items-center justify-center font-serif text-2xl font-semibold shrink-0">
          CB
        </div>
        <div class="flex-1">
          <h2 class="font-serif text-2xl font-semibold mb-1">Cristian Baeza Torres</h2>
          <p class="font-mono text-sm text-bone-200/70 mb-4">@CBaezaT</p>
          <a href="https://github.com/CBaezaT" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-bone-100 px-4 py-2 font-mono text-xs uppercase tracking-widest hover:bg-bone-100 hover:text-ink transition-colors duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Ver perfil en GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Repositorios Destacados -->
    <div class="space-y-5">
      <h2 class="font-serif text-2xl font-semibold text-ink">Repositorios Destacados</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-bone-300 border border-bone-300">
        {repos.map((repo, index) => (
          <div class="bg-bone-50 hover:bg-bone-100 transition-colors duration-200 p-6 space-y-4">
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-serif text-lg font-semibold text-ink">{repo.title}</h3>
              <span class="font-mono text-xs text-clay shrink-0 pt-1">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <p class="text-sm text-ink-light leading-relaxed">
              {repo.desc}
            </p>
            <div class="flex items-center justify-between pt-3 border-t border-bone-300">
              <div class="flex items-center gap-3 font-mono text-xs text-ink-light uppercase tracking-wide">
                <span class="border border-bone-300 px-2 py-1">{repo.lang}</span>
                <span>{repo.year}</span>
              </div>
              <a href={repo.href} target="_blank" rel="noopener noreferrer" class="font-mono text-xs uppercase tracking-widest text-ink hover:text-clay transition-colors duration-200">
                Ver repositorio →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Tecnologías que uso -->
    <div class="space-y-5">
      <h2 class="font-serif text-2xl font-semibold text-ink">Tecnologías que uso</h2>
      <div class="flex flex-wrap gap-2">
        {tecnologias.map((tech) => (
          <span class="border border-bone-300 text-ink-light px-4 py-2 font-mono text-xs uppercase tracking-wide">
            {tech}
          </span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-ink text-bone-100 p-10 relative overflow-hidden">
      <div class="absolute top-0 left-0 h-[3px] w-full bg-gradient-to-r from-clay via-clay-light to-moss"></div>
      <h2 class="font-serif text-2xl font-semibold mb-3">¿Quieres colaborar?</h2>
      <p class="text-bone-200/80 mb-6 max-w-2xl leading-relaxed">
        Todos mis proyectos son de código abierto. Si te interesa colaborar en alguno de ellos
        o tienes alguna idea, no dudes en hacer un fork, abrir un issue o contactarme directamente.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="https://github.com/CBaezaT" target="_blank" rel="noopener noreferrer" class="border border-bone-100 px-6 py-3 font-mono text-xs uppercase tracking-widest hover:bg-bone-100 hover:text-ink transition-colors duration-200">
          Ver todos mis repositorios
        </a>
        <a href={`${base}contacto`} class="bg-bone-100 text-ink px-6 py-3 font-mono text-xs uppercase tracking-widest hover:bg-clay-light hover:text-bone-100 transition-colors duration-200">
          Contactarme
        </a>
      </div>
    </div>
  </div>
</Layout>
