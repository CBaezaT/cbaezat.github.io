---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - Cristian Baeza Torres">
  <div class="max-w-2xl mx-auto space-y-12">
    <div class="space-y-2 border-b border-bone-300 pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-clay">§ Contacto</p>
      <h1 class="font-serif text-4xl font-semibold text-ink">Contacto</h1>
      <p class="text-lg text-ink-light">¿Te gustaría conectar conmigo?</p>
    </div>

    <!-- Información de Contacto -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-bone-300 border border-bone-300">
      <div class="bg-bone-50 p-8 space-y-5">
        <h3 class="font-serif text-lg font-semibold text-ink">Información de Contacto</h3>

        <div class="space-y-5">
          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-clay mb-1">Email</p>
            <a href="mailto:cbaeza@udec.cl" class="text-ink hover:text-clay transition-colors duration-200">cbaeza@udec.cl</a>
          </div>

          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-clay mb-1">Institución</p>
            <p class="text-ink-light">Universidad de Concepción</p>
            <p class="text-sm text-ink-light/70">Concepción, Chile</p>
          </div>

          <div>
            <p class="font-mono text-xs uppercase tracking-widest text-clay mb-1">Redes Sociales</p>
            <div class="space-y-1">
              <a href="https://github.com/CBaezaT" target="_blank" rel="noopener noreferrer" class="block text-ink hover:text-clay transition-colors duration-200">
                GitHub · CBaezaT
              </a>
              <a href="https://www.linkedin.com/in/cristian-baeza-torres" target="_blank" rel="noopener noreferrer" class="block text-ink hover:text-clay transition-colors duration-200">
                LinkedIn
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Escríbeme directamente -->
      <div class="bg-bone-50 p-8 flex flex-col justify-center items-center text-center space-y-5">
        <div class="space-y-2">
          <h3 class="font-serif text-lg font-semibold text-ink">Escríbeme directamente</h3>
          <p class="text-ink-light text-sm leading-relaxed">
            La forma más rápida de contactarme es por correo electrónico. Respondo dentro de 48 horas.
          </p>
        </div>
        <a
          href="mailto:cbaeza@udec.cl"
          class="w-full bg-ink text-bone-100 px-6 py-3 font-mono text-xs uppercase tracking-widest hover:bg-clay-dark transition-colors duration-200 text-center"
        >
          Enviar email
        </a>
        <p class="font-mono text-xs text-ink-light/60">cbaeza@udec.cl</p>
      </div>
    </div>

    <!-- Información Adicional -->
    <div class="border border-bone-300 p-8 space-y-5">
      <h3 class="font-serif text-lg font-semibold text-ink">Otros Motivos para Contactarme</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <span class="font-mono text-clay pt-0.5">→</span>
          <p class="text-ink-light">Colaboraciones académicas y de investigación</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="font-mono text-clay pt-0.5">→</span>
          <p class="text-ink-light">Oportunidades de consultoría en data science</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="font-mono text-clay pt-0.5">→</span>
          <p class="text-ink-light">Invitaciones para seminarios o presentaciones</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="font-mono text-clay pt-0.5">→</span>
          <p class="text-ink-light">Tutoría y mentoría académica</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="font-mono text-clay pt-0.5">→</span>
          <p class="text-ink-light">Preguntas sobre antropología física o data science</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="font-mono text-clay pt-0.5">→</span>
          <p class="text-ink-light">Feedback y sugerencias sobre el sitio</p>
        </div>
      </div>
    </div>

    <!-- Tiempo de respuesta -->
    <div class="border-l-2 border-clay bg-bone-100 p-6">
      <p class="text-ink-light">
        <span class="font-mono text-xs uppercase tracking-widest text-clay-dark block mb-1">Tiempo de respuesta</span>
        Hago mi mejor esfuerzo para responder todos los mensajes dentro de 48 horas. Por favor, sé paciente si la respuesta demora un poco.
      </p>
    </div>
  </div>
</Layout>
