---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const formatearFecha = (d: Date) => `${d.getUTCDate()} de ${meses[d.getUTCMonth()]}, ${d.getUTCFullYear()}`;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Blog - Cristian Baeza Torres">
  <div class="max-w-4xl mx-auto space-y-12">
    <div class="space-y-2 border-b border-bone-300 pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-clay">§ Bitácora</p>
      <h1 class="font-serif text-4xl font-semibold text-ink">Blog</h1>
    </div>

    <div class="divide-y divide-bone-300 border-t border-bone-300">
      {posts.map((post) => (
        <article class="py-8 flex gap-6">
          <span class="font-mono text-sm text-clay shrink-0 pt-1">{post.data.date.getUTCFullYear()}</span>
          <div class="space-y-2">
            <h2 class="font-serif text-xl font-semibold text-ink">
              {post.body.trim().length > 0 ? (
                <a href={`${base}blog/${post.slug}`} class="hover:text-clay transition-colors duration-200">
                  {post.data.title}
                </a>
              ) : (
                post.data.title
              )}
            </h2>
            <p class="font-mono text-xs text-ink-light uppercase tracking-wide">{formatearFecha(post.data.date)}</p>
            <p class="text-ink-light leading-relaxed">{post.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
