---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog - Cristian Baeza Torres">
  <div class="max-w-4xl mx-auto space-y-12">
    <div class="space-y-2 border-b border-bone-300 pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-clay">§ Bitácora</p>
      <h1 class="font-serif text-4xl font-semibold text-ink">Blog</h1>
    </div>

    <div class="divide-y divide-bone-300 border-t border-bone-300">
      <article class="py-8 flex gap-6">
        <span class="font-mono text-sm text-clay shrink-0 pt-1">2021</span>
        <div class="space-y-2">
          <h2 class="font-serif text-xl font-semibold text-ink">Transcripción Automática</h2>
          <p class="font-mono text-xs text-ink-light uppercase tracking-wide">15 de Septiembre, 2021</p>
          <p class="text-ink-light leading-relaxed">
            Explorando herramientas de transcripción automática para investigación cualitativa.
          </p>
        </div>
      </article>

      <article class="py-8 flex gap-6">
        <span class="font-mono text-sm text-clay shrink-0 pt-1">2022</span>
        <div class="space-y-2">
          <h2 class="font-serif text-xl font-semibold text-ink">Proyecto de Tesis</h2>
          <p class="font-mono text-xs text-ink-light uppercase tracking-wide">15 de Febrero, 2022</p>
          <p class="text-ink-light leading-relaxed">
            Detalles sobre mi proyecto de investigación y metodología.
          </p>
        </div>
      </article>
    </div>
  </div>
</Layout>
