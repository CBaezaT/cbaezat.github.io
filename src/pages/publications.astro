---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const publicaciones = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year
);
---

<Layout title="Publicaciones - Cristian Baeza Torres">
  <div class="max-w-4xl mx-auto space-y-12">
    <div class="space-y-2 border-b border-bone-300 pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-clay">§ Bibliografía</p>
      <h1 class="font-serif text-4xl font-semibold text-ink">Publicaciones</h1>
      <p class="text-lg text-ink-light">Artículos y trabajos de investigación</p>
    </div>

    <div class="divide-y divide-bone-300 border-t border-bone-300">
      {publicaciones.map((pub) => (
        <article class="py-8 flex gap-6">
          <span class="font-mono text-sm text-clay shrink-0 pt-1">{pub.data.year}</span>
          <div class="space-y-2">
            <h2 class="font-serif text-xl font-semibold text-ink">{pub.data.title}</h2>
            {pub.data.cita && (
              <p class="text-sm text-ink-light font-mono">{pub.data.cita}</p>
            )}
            <p class="text-ink-light leading-relaxed">{pub.data.description}</p>
            {pub.data.url && (
              <a
                href={pub.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-widest text-ink hover:text-clay transition-colors duration-200 pt-1"
              >
                {pub.data.urlLabel}
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
