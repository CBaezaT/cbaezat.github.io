---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About me - Cristian Baeza Torres">
  <div class="max-w-4xl mx-auto space-y-12">
    <!-- Header con foto igual al inicio -->
    <div class="flex items-center gap-6">
      <img
        src="/bio-photo.jpg"
        alt="Cristian Baeza Torres"
        class="w-36 h-48 rounded-3xl object-cover shadow-md flex-shrink-0"
      />
      <div class="space-y-2">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight">Cristian Baeza Torres</h1>
        <p class="text-xl text-gray-600">Antropólogo Físico</p>
        <p class="text-lg text-gray-600">Estudiante Magíster en Ciencia de Datos para la Innovación</p>
        <p class="text-base text-gray-500">Universidad de Concepción - Concepción, Chile</p>
        <a
          href="mailto:cbaeza2016@udec.cl"
          class="inline-block mt-2 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-medium text-base shadow-md hover:shadow-lg"
        >
          Contáctame
        </a>
      </div>
    </div>

    <div class="space-y-8 text-gray-700">
      <!-- Introducción -->
      <section class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Introducción</h2>
        <p>
          Soy antropólogo físico / Data Scientist con una pasión por la innovación, 
          la aplicación de métodos cuantitativos y ciencia de datos 
          en el estudio de las poblaciones humanas y sus problemáticas. 
        </p>
        <p>
          Combino la formación clásica en antropología biológica con 
          herramientas modernas de análisis de datos e Inteligencia Artificial.
        </p>
        <p>
          Creo que la integración de enfoques interdisciplinarios es clave 
          para avanzar en la comprensión de distintas problemáticas 
          y desarrollar soluciones integrales a estas.
        </p>
      </section>

      <!-- Formación Académica -->
      <section class="space-y-4">
        <h2 class="text-2xl font-bold text-gray-900">Formación Académica</h2>
        <div class="space-y-3">
          <div class="bg-blue-50 p-4 rounded border-l-4 border-blue-600">
            <h3 class="font-semibold text-gray-900">Magíster en Ciencia de Datos para la Innovación</h3>
            <p class="text-sm text-gray-600">Facultad de Ingeniería, Universidad de Concepción</p>
            <p class="text-sm text-gray-500">En curso (2025-2026)</p>
          </div>
          <div class="bg-purple-50 p-4 rounded border-l-4 border-purple-600">
            <h3 class="font-semibold text-gray-900">Antropología con mención Física</h3>
            <p class="text-sm text-gray-600">Facultad de Ciencias Sociales, Universidad de Concepción</p>
            <p class="text-sm text-gray-500">Egresado</p>
          </div>
        </div>
      </section>

      <!-- Áreas de Expertise -->
      <section class="space-y-4">
        <h2 class="text-2xl font-bold text-gray-900">Áreas de Expertise</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-green-50 p-4 rounded">
            <h4 class="font-semibold text-gray-900 mb-2">Antropología Biológica</h4>
            <p class="text-sm text-gray-600">Análisis de poblaciones, variación humana, adaptación</p>
          </div>
          <div class="bg-blue-50 p-4 rounded">
            <h4 class="font-semibold text-gray-900 mb-2">Ciencia de Datos</h4>
            <p class="text-sm text-gray-600">Machine learning, análisis estadístico, visualización</p>
          </div>
          <div class="bg-purple-50 p-4 rounded">
            <h4 class="font-semibold text-gray-900 mb-2">Análisis Cuantitativo</h4>
            <p class="text-sm text-gray-600">Estadística, modelado, análisis multivariado</p>
          </div>
          <div class="bg-red-50 p-4 rounded">
            <h4 class="font-semibold text-gray-900 mb-2">Programación</h4>
            <p class="text-sm text-gray-600">Python, R, JavaScript, SQL</p>
          </div>
        </div>
      </section>

      <!-- Experiencia Profesional -->
      <section class="space-y-4">
        <h2 class="text-2xl font-bold text-gray-900">Experiencia Profesional</h2>
        <div class="space-y-3">
          <div class="border-l-4 border-red-600 pl-4">
            <h3 class="font-semibold text-gray-900">Presidente - SOCHIAB 2025-2026</h3>
            <p class="text-sm text-gray-600">Sociedad Chilena de Antropología Biológica</p>
            <p class="text-gray-700 text-sm mt-1">Liderando iniciativas de investigación, educación y promoción de la disciplina en Chile</p>
          </div>
          <div class="border-l-4 border-blue-600 pl-4">
            <h3 class="font-semibold text-gray-900">Colaborador - Universidad de Concepción</h3>
            <p class="text-sm text-gray-600">Docencia e Investigación desde 2022 a la fecha</p>
          </div>
          <div class="border-l-4 border-purple-600 pl-4">
            <h3 class="font-semibold text-gray-900">Founder - ARIACH</h3>
          </div>
          <div class="border-l-4 border-green-600 pl-4">
            <h3 class="font-semibold text-gray-900">Impacto Ambiental</h3>
            <p class="text-sm text-gray-600">Ejercicio profesional en proyectos de impacto ambiental a lo largo de Chile, ejerciendo como Antropólogo Físico desde 2022</p>
          </div>
        </div>
      </section>

      <!-- Intereses de Investigación -->
      <section class="space-y-4">
        <h2 class="text-2xl font-bold text-gray-900">Intereses de Investigación</h2>
        <ul class="space-y-2">
          <li class="flex items-start gap-3">
            <span class="text-blue-600">→</span>
            <span> Sistemas basados en Ontología y World Models</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600">→</span>
            <span>Análisis de sindemias: interacciones entre enfermedades y factores socioeconómicos</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600">→</span>
            <span>Aplicación de machine learning en epidemiología y antropología</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600">→</span>
            <span>Procesamiento de lenguaje natural para análisis cualitativo automatizado</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600">→</span>
            <span>Integración de métodos cuantitativos y cualitativos en investigación social</span>
          </li>
        </ul>
      </section>

      <!-- Valores -->
      <section class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-lg p-6 border-l-4 border-blue-600">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Mis Valores</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-700">
          <div class="flex items-start gap-3">
            <span class="text-2xl">📚</span>
            <div>
              <p class="font-semibold">Rigor Científico</p>
              <p class="text-sm">Investigación meticulosa y basada en evidencia</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl">🤝</span>
            <div>
              <p class="font-semibold">Colaboración</p>
              <p class="text-sm">Trabajo interdisciplinario y comunicación abierta</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl">💡</span>
            <div>
              <p class="font-semibold">Innovación</p>
              <p class="text-sm">Exploración de nuevos métodos y enfoques</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl">🌍</span>
            <div>
              <p class="font-semibold">Impacto Social</p>
              <p class="text-sm">Investigación que contribuya al bien común</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
