---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Antropólogo Físico, Estudiante del Magíster en Ciencia de Datos para la Innovación' } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/bio-photo.jpg', Astro.site);
// Primer segmento de la URL: marca la sección activa en el nav
const currentSection = Astro.url.pathname.split('/').filter(Boolean)[0] ?? '';

const navLinks = [
  { href: 'about', label: 'Sobre mí' },
  { href: 'proyectos', label: 'Proyectos' },
  { href: 'publications', label: 'Publicaciones' },
  { href: 'repositorios', label: 'Repositorios' },
  { href: 'docencia', label: 'Docencia' },
  { href: 'contacto', label: 'Contacto' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Cristian Baeza Torres" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global>
      :focus-visible {
        outline: 2px solid #b45309;
        outline-offset: 2px;
      }
    </style>
  </head>
  <body class="bg-bone-100 text-ink min-h-screen flex flex-col font-sans antialiased">
    <header class="bg-bone-100/95 backdrop-blur border-b border-bone-300 sticky top-0 z-30">
      <nav class="max-w-6xl mx-auto px-6 sm:px-8 py-5">
        <div class="flex justify-between items-center">
          <a href={base} class="font-serif text-xl font-semibold text-ink tracking-tight">
            Cristian Baeza Torres
          </a>

          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-8">
            {navLinks.map((link) => (
              <a
                href={`${base}${link.href}`}
                aria-current={link.href === currentSection ? 'page' : undefined}
                class:list={[
                  'font-mono text-xs uppercase tracking-widest transition-colors duration-200',
                  link.href === currentSection ? 'text-clay' : 'text-ink-light hover:text-clay',
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>

          <!-- Hamburger button (mobile) -->
          <button
            id="menu-toggle"
            class="md:hidden text-ink focus:outline-none"
            aria-label="Abrir menú"
            aria-expanded="false"
          >
            <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <!-- Mobile menu: full-screen panel -->
    <div id="mobile-menu" class="hidden md:hidden fixed inset-0 top-[73px] bg-bone-100 z-20 overflow-y-auto">
      <div class="flex flex-col px-8 py-6">
        {navLinks.map((link) => (
          <a
            href={`${base}${link.href}`}
            class="font-serif text-2xl text-ink py-4 border-b border-bone-300 min-h-[44px] flex items-center"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <main class="max-w-6xl mx-auto px-6 sm:px-8 py-12 flex-grow w-full">
      <slot />
    </main>

    <footer class="bg-ink text-bone-200 mt-auto relative">
      <div class="h-[3px] bg-gradient-to-r from-clay via-clay-light to-moss"></div>
      <div class="max-w-6xl mx-auto px-6 sm:px-8 py-10">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <p class="font-mono text-xs text-bone-300/70 tracking-wide">© {currentYear} Cristian Baeza Torres</p>
          <div class="flex gap-6 font-mono text-xs uppercase tracking-widest">
            <a href="https://github.com/CBaezaT" target="_blank" rel="noopener noreferrer" class="hover:text-clay-light transition-colors duration-200">GitHub</a>
            <a href="https://www.linkedin.com/in/cristian-baeza-torres" target="_blank" rel="noopener noreferrer" class="hover:text-clay-light transition-colors duration-200">LinkedIn</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
        document.body.classList.toggle('overflow-hidden', !isOpen);
      });
    </script>
  </body>
</html>
